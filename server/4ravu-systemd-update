#!/usr/bin/env bash
# 4ravu-systemd-update <container-name>
#
# Updates /etc/systemd/system/container-4ravu.service to start whichever
# container slot is now active (4ravu-blue or 4ravu-green).
#
# Called automatically by 4ravu-deploy.sh after each successful deploy.
# Can also be run manually to repair the systemd unit after a server setup.
#
# Usage:
#   sudo /usr/local/bin/4ravu-systemd-update 4ravu-green
#   sudo /usr/local/bin/4ravu-systemd-update 4ravu-blue
#
# Installed by: 4ravu-setup.sh
# Destination:  /usr/local/bin/4ravu-systemd-update (chmod 755, root:root)
# Sudoers:      deploy ALL=(ALL) NOPASSWD: /usr/local/bin/4ravu-systemd-update
#
# Notes:
#   - Uses `podman generate systemd --new` so the service creates a fresh container
#     on reboot using the original `podman run` arguments stored in the container
#     metadata (volumes and port mappings are preserved automatically).
#   - Fixes WantedBy=default.target → multi-user.target (podman generates user-scope
#     target by default, which systemd rejects for system-level services).
#   - Calls restorecon to fix the SELinux context (files moved from /tmp would
#     otherwise carry user_tmp_t and be unreadable by systemd on AlmaLinux/RHEL).

set -euo pipefail

CONTAINER_NAME="${1:?Usage: $0 <container-name>}"
SERVICE_FILE=/etc/systemd/system/container-4ravu.service

podman generate systemd \
    --name "$CONTAINER_NAME" \
    --restart-policy always \
    --new \
    | sed 's/WantedBy=default\.target/WantedBy=multi-user.target/' \
    > /tmp/4ravu-app.service

mv /tmp/4ravu-app.service "$SERVICE_FILE"
restorecon -v "$SERVICE_FILE" 2>/dev/null || true
systemctl daemon-reload
systemctl enable container-4ravu.service

echo "container-4ravu.service updated -> $CONTAINER_NAME"
